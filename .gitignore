# Terraform state files - never push these
terraform.tfstate
terraform.tfstate.backup

# Terraform lock file for local use
.terraform.lock.hcl

# Terraform working directory
.terraform/

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json